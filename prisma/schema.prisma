// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  passwordHash     String            @map("password_hash")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  directoryMembers DirectoryMember[]

  @@map("users")
}

model DirectoryMember {
  id               String                    @id @default(cuid())
  gamertag         String
  displayName      String?                   @map("display_name")
  phone            String
  phoneCountry     String?                   @map("phone_country")
  active           Boolean                   @default(true) @map("is_active")
  /**
   * Activo permanente en el roster de WhatsApp: aunque Minecraft marque inactividad,
   * no se baja a «inactivo» mientras esté activado.
   */
  permanentlyActive Boolean                  @default(false) @map("permanently_active")
  /**
   * Tras marcar activo a mano, el sync de Minecraft no vuelve a poner inactivo
   * hasta que lo marques inactivo otra vez (salvo activo permanente).
   */
  activeHoldFromMc Boolean                    @default(false) @map("active_hold_from_mc")
  /** Pendiente de `allowlist add` (p. ej. reactivación manual inactivo → activo). */
  allowlistAddPending Boolean                 @default(false) @map("allowlist_add_pending")
  /** Última vez que su gamertag se dio de alta en el allowlist vía sync web. */
  allowlistSyncedAt DateTime?                @map("allowlist_synced_at")
  /** Última vez que su gamertag se quitó del allowlist vía sync web. */
  allowlistRemovedAt DateTime?               @map("allowlist_removed_at")
  isAdmin          Boolean                   @default(false) @map("is_admin")
  banExempt        Boolean                   @default(false) @map("ban_exempt")
  leftAt           DateTime?                 @map("left_at")
  banned           Boolean                   @default(false) @map("banned")
  bannedReason     String?                   @map("banned_reason")
  notes            String?
  userId           String                    @map("user_id")
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  strikes          DirectoryStrike[]
  auditSuggestions GamertagAuditSuggestion[]
  gamertagCorrections PendingGamertagCorrection[]
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  @@map("directory_members")
}

model DirectoryStrike {
  id        String          @id @default(cuid())
  reason    String
  memberId  String          @map("member_id")
  member    DirectoryMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([memberId])
  @@map("directory_strikes")
}

/**
 * Cola panel ↔ addon: peticiones de sync (id fijo `minecraft_sync_request`).
 */
model MinecraftSyncQueue {
  id        String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("minecraft_sync_queue")
}

/**
 * Registro de actividad de jugadores de Minecraft desde el servidor
 */
model MinecraftPlayer {
  id               String                    @id @default(cuid())
  gamertag         String                    @unique
  lastSeen         DateTime                  @map("last_seen")
  active           Boolean                   @default(true)
  daysInactive     Int                       @default(0) @map("days_inactive")
  isBlacklisted    Boolean                   @default(false) @map("is_blacklisted")
  isWhitelisted    Boolean                   @default(false) @map("is_whitelisted")
  auditSuggestions GamertagAuditSuggestion[]
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  @@map("minecraft_players")
}

/**
 * Snapshot de datos del servidor de Minecraft (histórico)
 */
model MinecraftSnapshot {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  totalPlayers    Int      @map("total_players")
  activePlayers   Int      @map("active_players")
  inactivePlayers Int      @map("inactive_players")
  data            Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@map("minecraft_snapshots")
}

/**
 * Configuración del sistema de Minecraft (editable desde web)
 */
model MinecraftConfig {
  id                    String   @id @default("default")
  daysInactive          Int      @default(7) @map("days_inactive")
  daysBlacklist         Int      @default(14) @map("days_blacklist")
  daysPurge             Int      @default(21) @map("days_purge")
  /**
   * Días de historial de snapshots en Neon antes de borrar (no afecta jugadores actuales).
   */
  snapshotRetentionDays Int      @default(45) @map("snapshot_retention_days")
  /**
   * Mínimo de snapshots recientes que nunca se purgan por antigüedad.
   */
  snapshotKeepMinimum   Int      @default(10) @map("snapshot_keep_minimum")
  parcelEnabled         Boolean  @default(false) @map("parcel_enabled")
  parcelName            String   @default("Parcela") @map("parcel_name")
  parcelDimension       String   @default("overworld") @map("parcel_dimension")
  parcelMinX            Int      @default(0) @map("parcel_min_x")
  parcelMinY            Int      @default(64) @map("parcel_min_y")
  parcelMinZ            Int      @default(0) @map("parcel_min_z")
  parcelMaxX            Int      @default(15) @map("parcel_max_x")
  parcelMaxY            Int      @default(79) @map("parcel_max_y")
  parcelMaxZ            Int      @default(15) @map("parcel_max_z")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("minecraft_config")
}

/**
 * Entrada o salida de un jugador en la parcela monitoreada
 */
model MinecraftParcelEvent {
  id         String   @id @default(cuid())
  gamertag   String
  eventType  String   @map("event_type")
  occurredAt DateTime @map("occurred_at")
  posX       Int?     @map("pos_x")
  posY       Int?     @map("pos_y")
  posZ       Int?     @map("pos_z")
  dimension  String?
  blockType  String?  @map("block_type")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([occurredAt(sort: Desc)])
  @@index([gamertag])
  @@map("minecraft_parcel_events")
}

/**
 * Mini auditoría: gamertag visto en Minecraft muy parecido (no exacto) al de un
 * miembro del directorio (WhatsApp). Requiere aprobación manual antes de
 * sobreescribir el gamertag del directorio (probablemente mal escrito).
 */
model GamertagAuditSuggestion {
  id                String          @id @default(cuid())
  directoryMemberId String          @map("directory_member_id")
  directoryMember   DirectoryMember @relation(fields: [directoryMemberId], references: [id], onDelete: Cascade)
  minecraftPlayerId String          @map("minecraft_player_id")
  minecraftPlayer   MinecraftPlayer @relation(fields: [minecraftPlayerId], references: [id], onDelete: Cascade)
  /**
   * Gamertag del directorio en el momento de detectar la sugerencia.
   */
  currentGamertag   String          @map("current_gamertag")
  /**
   * Gamertag visto en Minecraft que se propone usar en su lugar.
   */
  suggestedGamertag String          @map("suggested_gamertag")
  /**
   * Similitud 0-1 (Levenshtein normalizado, considerando sufijos numéricos).
   */
  similarity        Float
  /**
   * pending | approved | rejected
   */
  status            String          @default("pending")
  decidedAt         DateTime?       @map("decided_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([directoryMemberId, minecraftPlayerId], map: "gamertag_audit_suggestions_member_player_key")
  @@index([status])
  @@map("gamertag_audit_suggestions")
}

/**
 * Corrección de gamertag pendiente de reflejar en el allowlist real del
 * servidor (`allowlist remove <viejo>` + `allowlist add <nuevo>`). Se crea
 * tanto al aprobar una sugerencia de la mini auditoría como al editar el
 * gamertag a mano desde la ficha del miembro (cualquier cambio de gamertag
 * de un miembro del roster queda registrado aquí, con el mismo origen que
 * quien lo hizo).
 */
model PendingGamertagCorrection {
  id                String          @id @default(cuid())
  directoryMemberId String          @map("directory_member_id")
  directoryMember   DirectoryMember @relation(fields: [directoryMemberId], references: [id], onDelete: Cascade)
  oldGamertag       String          @map("old_gamertag")
  newGamertag       String          @map("new_gamertag")
  /**
   * Cuándo el addon aplicó en el servidor allowlist add/remove para esta
   * corrección. Null = aún pendiente de sincronizar.
   */
  syncedAt          DateTime?       @map("synced_at")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([syncedAt])
  @@map("pending_gamertag_corrections")
}

/**
 * Gamertags que deben quitarse del allowlist del servidor (miembro inactivo/salido,
 * ficha borrada o nombre viejo tras corrección). `syncedAt` null = pendiente.
 */
model PendingAllowlistRemoval {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  gamertag  String
  syncedAt  DateTime? @map("synced_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, syncedAt])
  @@map("pending_allowlist_removals")
}
