// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  passwordHash     String            @map("password_hash")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  directoryMembers DirectoryMember[]

  @@map("users")
}

model DirectoryMember {
  id           String            @id @default(cuid())
  gamertag     String
  displayName  String?           @map("display_name")
  phone        String
  phoneCountry String?           @map("phone_country")
  active       Boolean           @default(true) @map("is_active")
  isAdmin      Boolean           @default(false) @map("is_admin")
  banExempt    Boolean           @default(false) @map("ban_exempt")
  leftAt       DateTime?         @map("left_at")
  banned       Boolean           @default(false) @map("banned")
  bannedReason String?           @map("banned_reason")
  notes        String?
  userId       String            @map("user_id")
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  strikes      DirectoryStrike[]
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@map("directory_members")
}

model DirectoryStrike {
  id        String          @id @default(cuid())
  reason    String
  memberId  String          @map("member_id")
  member    DirectoryMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([memberId])
  @@map("directory_strikes")
}

/** Parámetros JSON editables desde el panel; el bot puede leerlos vía GET /api/bot/panel-config */
model BotPanelSettings {
  id        String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bot_panel_settings")
}

/** Registro de actividad de jugadores de Minecraft desde el servidor */
model MinecraftPlayer {
  id              String   @id @default(cuid())
  gamertag        String   @unique
  lastSeen        DateTime @map("last_seen")
  active          Boolean  @default(true)
  daysInactive    Int      @default(0) @map("days_inactive")
  isBlacklisted   Boolean  @default(false) @map("is_blacklisted")
  isWhitelisted   Boolean  @default(false) @map("is_whitelisted")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("minecraft_players")
}

/** Snapshot de datos del servidor de Minecraft (histórico) */
model MinecraftSnapshot {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  totalPlayers    Int      @map("total_players")
  activePlayers   Int      @map("active_players")
  inactivePlayers Int      @map("inactive_players")
  data            Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@map("minecraft_snapshots")
}

/** Configuración del sistema de Minecraft (editable desde web) */
model MinecraftConfig {
  id                String   @id @default("default")
  daysInactive      Int      @default(7) @map("days_inactive")
  daysBlacklist     Int      @default(14) @map("days_blacklist")
  daysPurge         Int      @default(21) @map("days_purge")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("minecraft_config")
}
