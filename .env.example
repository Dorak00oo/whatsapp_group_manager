# Neon: copia solo la URL (postgresql://...), no el comando "psql '...'".
# Usa sslmode=verify-full (recomendado por `pg` / Neon) para evitar avisos de deprecación.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full"

# Secreto para firmar sesiones (generar: openssl rand -base64 32)
AUTH_SECRET=""

# Pon AUTH_DEBUG=1 para ver en consola del servidor por qué falla el login (quítalo después)
# AUTH_DEBUG="1"

# Única cuenta comunitaria (no hay registro público)
COMMUNITY_EMAIL="comunidad@ejemplo.local"
COMMUNITY_PASSWORD="cambia-esta-contraseña"
# Opcional: nombre que verás en el panel
# COMMUNITY_DISPLAY_NAME="Comunidad"

# Si `npm run dev` usa otro puerto (ej. 3001), define el origen exacto:
# AUTH_URL="http://localhost:3001"

# Opcional en local; en Vercel se infiere. Producción:
# AUTH_URL="https://tu-dominio.vercel.app"
